{
  "name": "gate-bot-gui",
  "version": "1.0.0",
  "description": "Gate.io BTC 自动交易机器人",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.gatebot.v10",
    "productName": "Gate BTC 机器人",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["zh_CN"]
    },
    "files": ["src/**/*", "assets/**/*"],
    "extraFiles": []
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
